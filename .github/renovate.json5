{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  minimumReleaseAge: '1 month',
  dependencyDashboard: true,
  extends: [
    'config:recommended',
  ],
  ignorePresets: [
    'workarounds:javaLTSVersions',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^\\.java-version$/',
      ],
      matchStrings: [
        '(?<currentValue>.*)\\n',
      ],
      datasourceTemplate: 'java-version',
      depNameTemplate: 'java',
      extractVersionTemplate: '^(?<version>\\d+)',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^README\\.md$/',
      ],
      matchStrings: [
        'id\\s+"(?<depName>io\\.github\\.5peak2me\\.kcp\\.tracing)"\\s+version\\s+"(?<currentValue>[^"]+)"',
        'classpath\\s+"(?<depName>io\\.github\\.5peak2me\\.kcp\\.tracing):gradle-plugin:(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'maven',
      packageNameTemplate: '{{{depName}}}:{{{depName}}}.gradle.plugin',
      registryUrlTemplate: 'https://plugins.gradle.org/m2/',
      versioningTemplate: 'maven',
    },
  ],
  forkProcessing: 'enabled',
  packageRules: [
    {
      matchUpdateTypes: [
        'patch',
        'minor',
        'pin',
        'digest',
      ],
      automerge: true,
      automergeType: 'branch',
    },
  ],
}
